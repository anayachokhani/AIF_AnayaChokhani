# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.tools
/.venv
/.uv-cache
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
.pytest_cache/
__pycache__/
*.py[cod]

# next.js
/.next/
/.vinext/
/out/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# local data and generated artifacts
/data/raw/
/data/external/
/data/vectorstores/
/data/saved_designs/
/artifacts/demo/*.mp4
/artifacts/demo/*.mov
/artifacts/demo/*.webm
/artifacts/demo/screenshots/
/artifacts/metrics/raw/
/artifacts/generated/

# vercel
.vercel

# typescript
next-env.d.ts
/dist/
/.wrangler/
/outputs/
/work/
